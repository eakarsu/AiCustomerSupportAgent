{
  "name": "ai-customer-support-backend",
  "version": "1.0.0",
  "description": "AI Customer Support Agent Backend",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "db:generate": "dotenv -e ../.env -- prisma generate",
    "db:push": "dotenv -e ../.env -- prisma db push --accept-data-loss",
    "db:seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "jsonwebtoken": "^9.0.2",
    "openai": "^4.28.0",
    "twilio": "^4.23.0",
    "uuid": "^9.0.1",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "dotenv-cli": "^7.4.2",
    "prisma": "^5.10.0"
  }
}
